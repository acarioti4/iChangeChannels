# Discord bot token for iChangeChannels.
DISCORD_BOT_TOKEN=

# The numeric Discord user ID of the dedicated streaming account.
STREAM_USER_ID=
# Display name used only in status/error messages. Set it to your streaming
# account's name, or leave it as-is.
STREAM_USERNAME=the stream account

# Used by desktop automation to open the DM containing the join link.
DISCORD_DM_SEARCH=iChangeChannels

COMMAND_SYNC_ON_START=true

# Android TV Remote Protocol v2 connection.
#
# Leave ANDROID_TV_HOST blank to autopopulate it: when you run
# scripts\pair_android_tv.py it scans the network for Android TV Remote
# Protocol devices, lets you pick one, and writes the selected host back into
# this line for you. Set it manually only if you already know the TV's IP or
# hostname. The bot itself requires a value, so pair first if you leave it blank.
#
# Do not leave ANDROID_TV_CERTFILE, ANDROID_TV_KEYFILE, or
# ANDROID_TV_CLIENT_NAME blank; those are the pairing identity files/name.
ANDROID_TV_HOST=
ANDROID_TV_CERTFILE=data/androidtv_cert.pem
ANDROID_TV_KEYFILE=data/androidtv_key.pem
ANDROID_TV_CLIENT_NAME=iChangeChannels

# VLC.
VLC_PATH=C:\Program Files\VideoLAN\VLC\vlc.exe
# Capture-card default based on the older working project. Keep VLC visible in
# the background rather than minimized so Discord can pick the window quickly.
VLC_ARGS=dshow:// :dshow-fps=60 --preferred-resolution=1080p
VLC_PROCESS_NAMES=vlc.exe,vlc
VLC_WINDOW_TITLE=VLC media player
# Set by scripts\capture_vlc_window.py using the current live VLC window.
# Format: left,top,width,height
VLC_WINDOW_RECT=
# Windows show command from the captured window. 1=normal, 3=maximized.
VLC_WINDOW_SHOW_CMD=

# Timing.
ANDROID_TV_POWER_TIMEOUT_SECONDS=12
DISCORD_JOIN_TIMEOUT_SECONDS=20
DISCORD_STREAM_TIMEOUT_SECONDS=25
VLC_START_TIMEOUT_SECONDS=8

# Desktop automation. Keep enabled on the dedicated streaming server.
DESKTOP_AUTOMATION_ENABLED=true

# Remote key spam protection. Accepted key presses are serialized before being
# sent to Android TV; over-limit input fails loudly and is logged.
REMOTE_KEY_RATE_PER_SECOND=10
REMOTE_KEY_BURST=5
REMOTE_NUMBER_RATE_PER_SECOND=6
REMOTE_NUMBER_BURST=3
REMOTE_KEY_QUEUE_LIMIT=5

# Runtime files.
DATA_DIR=data
LOG_FILE=data/ichannel.log
